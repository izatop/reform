{
    "name": "reform",
    "version": "0.2.0",
    "private": true,
    "repository": "https://github.com/izatop/reform",
    "author": {
        "name": "Artur Bier",
        "email": "izatop@gmail.com"
    },
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "publish": "lerna publish --conventional-commits --yes",
        "clean": "lerna run build:clean",
        "build:watch": "tsc -b packages -w",
        "build:pg": "yarn workspace pg build:dev",
        "build:pg:time": "yarn workspace pg build:dev:time",
        "watch": "sh ./watch.sh",
        "ci:build": "sh ./build.sh",
        "ci:coveralls": "cat ./coverage/lcov.info | yarn coveralls",
        "test": "yarn test:clean && jest --config jest.json --coverage",
        "test:clean": "rimraf coverage",
        "test:watch": "jest --config jest.json --watch",
        "storybook": "start-storybook -p 6006",
        "build-storybook": "build-storybook"
    },
    "devDependencies": {
        "@babel/core": "^7.12.13",
        "@storybook/addon-actions": "^6.1.16",
        "@storybook/addon-essentials": "^6.1.16",
        "@storybook/addon-links": "^6.1.16",
        "@storybook/preset-scss": "^1.0.3",
        "@storybook/react": "^6.1.16",
        "@types/jest": "^26.0.19",
        "@types/react-test-renderer": "^17.0.0",
        "babel-loader": "^8.2.2",
        "coveralls": "^3.1.0",
        "css-loader": "^5.0.1",
        "husky": "^4.3.8",
        "jest": "^26.6.3",
        "jest-serializer-path": "^0.1.15",
        "lerna": "^3.22.1",
        "react": "^17.0.1",
        "react-test-renderer": "^17.0.1",
        "rimraf": "^3.0.2",
        "sass-loader": "^10.1.1",
        "style-loader": "^2.0.0",
        "ts-jest": "^26.5.0",
        "typescript": "^4.2.0-dev.20210201"
    },
    "license": "MIT",
    "dependencies": {
        "@storybook/addon-docs": "^6.1.16"
    }
}
